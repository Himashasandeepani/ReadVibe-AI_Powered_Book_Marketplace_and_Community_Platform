# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=readvibe_db
DB_USER=postgres
DB_PASSWORD=readvibe_password

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# API Configuration
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Email Configuration
EMAIL_ENABLED=false
EMAIL_FROM=noreply@readvibe.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
