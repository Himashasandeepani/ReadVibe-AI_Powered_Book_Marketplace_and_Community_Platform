# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=readvibe_db
DB_USER=postgres
DB_PASSWORD=readvibe_password

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# API Configuration
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Email Configuration
EMAIL_ENABLED=true
EMAIL_FROM=readvibe.noreply@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=readvibe.noreply@gmail.com
SMTP_PASS=your_smtp_app_password_here
